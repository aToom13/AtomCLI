{
  "$schema": "https://atomcli.ai/config.json",
  "model": "atomcli/minimax-m2.5-free",
  "provider": {
    "atomcli": {
      "models": {
        "minimax-m2.1-free": {
          "name": "Minimax-M2.5-Custom",
          "limit": {
            "context": 100000,
            "output": 4096
          }
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    }
  },
  "experimental": {
    "smart_model_routing": false,
    "auto_mode": "balanced",
    "auto_router": {
      "excluded_models": [],
      "model_ratings": {
        "deepseek-v4-flash-free": {
          "coding": 2,
          "documentation": 2,
          "analysis": 2,
          "general": 2
        }
      },
      "category_overrides": {}
    }
  }
}